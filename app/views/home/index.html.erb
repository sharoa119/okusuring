<!-- app/views/home/index.html.erb -->

<% if current_user %>

  <h1>今日のお薬の予定</h1>

  <h2>自分の予定</h2>

  <% if @my_times.any? %>
    <ul>
      <% @my_times.each do |time| %>
        <li class="med-item">
          <span class="med-time">
            <%= time.time.strftime("%H:%M") %>
          </span>
          <span class="med-target">
            <%= time.medication_schedule.target_name %>
          </span>
          <%= link_to time.medication_schedule.title,
              medication_schedule_path(time.medication_schedule) %>
            
          <% if time.taken_today? %>
            <span class="done">✔ 済</span>
          <% else %>
            <span class="med-action">
              <%= button_to "飲んだよ",
                    medication_time_medication_records_path(time) %>
            </span>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p>今日の服薬予定はありません</p>
  <% end %>

  <p>
    ＋ <%= link_to "新しい服薬スケジュールを登録", new_medication_schedule_path %>
  </p>

  <hr>

  <h2>家族の予定</h2>

  <% if @family_times.any? %>
    <ul>
      <% @family_times.each do |time| %>
        <li>
          <%= link_to time.medication_schedule.title,
                      medication_schedule_path(time.medication_schedule) %>
          <%= time.medication_schedule.target_name %>
          <%= time.time.strftime("%H:%M") %>
          <span class="readonly">閲覧のみ</span>
        </li>
      <% end %>
    </ul>
  <% elsif @has_family_links %>
    <p>今日のお薬の予定はありません</p>
  <% else %>
    <p>まだ家族と共有していません</p>

    <%= link_to "＋ 家族を招待する", family_links_path %>
  <% end %>
<% else %>
  <div class="lp-container">
    <h1 class="lp-logo">おくすリング</h1>

    <p>
      おくすリングは、自分や家族の服薬の飲み忘れを防ぐことに特化した、
      シンプルなリマインダーサービスです。
    </p>

    <p>
      服薬時間になるとLINEで通知が届き、
      「飲んだよ」を記録できます。
      家族共有を使うことで、家族の服薬状況も見守れます。
    </p>

    <p>
      おくすリングでは、服薬時間の通知や家族共有に
      LINEを利用しています。
      そのため、LINEアカウントでログインしてご利用ください。
    </p>

    <%= button_to "LINE公式アカウントでログイン",
        "/auth/line",
        method: :post,
        data: { turbo: false } %>

    <p class="lp-links">
      <%= link_to "利用規約", terms_path %>
      ｜
      <%= link_to "プライバシーポリシー", privacy_path %>
    </p>
  </div>
<% end %>
