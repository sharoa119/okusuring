<!-- app/views/medication_schedules/show.html.erb -->


<% content_for :title, "お薬の詳細 | おくすリング" %>
<% content_for :page_title, "お薬の詳細" %>
<% content_for :description, "登録した服薬スケジュールの内容を確認できます。" %>

<div class="page-container">
  <dl class="detail-list">
    <div class="detail-row">
      <dt class="detail-label">タイトル</dt>
      <dd class="detail-value"><%= @medication_schedule.title %></dd>
    </div>

    <div class="detail-row">
      <dt class="detail-label">飲む人</dt>
      <dd class="detail-value">
        <span class="med-target">
          <%= @medication_schedule.target_name %>
        </span>
      </dd>
    </div>

    <div class="detail-row">
      <dt class="detail-label">飲む時間</dt>
      <dd>
        <ul class="detail-time-list">
          <% @medication_schedule.medication_times.each do |time| %>
            <li class="detail-time-item">
              <time class="detail-time" datetime="<%= time.time.strftime("%H:%M") %>">
                <%= time.time.strftime("%H:%M") %>
              </time>

              <%= medication_status_badge(time.taken_today?) %>
            </li>
          <% end %>
        </ul>
      </dd>
    </div>

    <div class="detail-row">
      <dt class="detail-label">メモ</dt>
      <% if @medication_schedule.memo.present? %>
        <dd class="detail-memo"><%= @medication_schedule.memo %></dd>
      <% else %>
        <dd class="detail-memo detail-empty">メモはありません</dd>
      <% end %>
    </div>
  </dl>

  <% if @readonly %>
    <p>閲覧専用です</p>
  <% else %>
    <div class="detail-actions">
      <%= link_to "編集",
        edit_medication_schedule_path(@medication_schedule),
        class: "app-button" %>
      <%= button_to "この予定を削除",
            medication_schedule_path(@medication_schedule),
            method: :delete,
            data: { turbo_confirm: "本当に削除しますか？" },
            class: "schedule-delete-button" %>
    </div>
  <% end %>
</div>
